# Supabase — Project Settings → API (https://supabase.com/dashboard)
# Copy this file to .env.local and fill in real values. Restart `npm run dev` after saving.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: canonical site URL for email confirmation links (defaults to the page you sign up on).
# In Vercel, add your production URL, e.g. https://your-app.vercel.app
# Supabase → Authentication → URL Configuration: set Site URL to the same, and add Redirect URLs
# for https://your-app.vercel.app/** and http://localhost:5173/** for local dev.
# VITE_SITE_URL=https://your-app.vercel.app
